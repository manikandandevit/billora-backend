# =============================================================================
# Billora / Gravity — Django backend (.env.example → copy to `.env` or Render)
# Every key here maps to os.environ usage in config/settings.py
# NEVER commit `.env` with real secrets.
# =============================================================================

# --- Core ---
# Production: ≥48 random chars — python -c "import secrets; print(secrets.token_hex(32))"
DJANGO_SECRET_KEY=replace-with-openssl-rand-hex-32-or-longer-random-string

DEBUG=True

# Comma-separated hosts. Examples:
#   Local: ALLOWED_HOSTS=127.0.0.1,localhost
#   Render (easy / less strict): ALLOWED_HOSTS=* 
#     (any Host accepted — prefer naming your *.onrender.com host when stable)
#   Render (better): ALLOWED_HOSTS=my-api.onrender.com
ALLOWED_HOSTS=127.0.0.1,localhost

DJANGO_TIME_ZONE=UTC

# Public API URL (no trailing slash). Logo/media JSON URLs for Vercel + Render. Example: https://api.onrender.com
PUBLIC_API_BASE_URL=

# --- TLS stack (HTTPS / Render reverse proxy): set USE_TLS=1 in production ---
USE_TLS=0
TRUST_PROXY_SSL=0
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=1
SECURE_HSTS_PRELOAD=0
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

# --- Database (leave DB_PASSWORD empty locally → SQLite) ---
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=0

# --- Browser origins (comma, no trailing slash) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://billora-frontend.vercel.app

# Omit → settings uses built-in Billora Vercel preview regex | none | false | 0 → disable regex entirely
# CORS_ALLOWED_ORIGIN_REGEXES=

# Empty → defaults to same list as CORS_ALLOWED_ORIGINS. Set if SPA + API origins differ for cookie CSRF:
# CSRF_TRUSTED_ORIGINS=https://my-api.onrender.com,https://billora-frontend.vercel.app

# --- JWT ---
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=14
JWT_LEEWAY_SECONDS=5
JWT_LOGIN_THROTTLE=20/minute
JWT_REFRESH_THROTTLE=60/minute
DRF_ANON_THROTTLE=120/minute
JWT_ISSUER=
JWT_AUDIENCE=

# --- Email (optional: if EMAIL_HOST empty → console backend) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Billora <noreply@billora.local>
BILLORA_RECEIVER_EMAIL=

# --- First superuser for Render build: python manage.py ensure_superuser ---
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# =============================================================================
# Render: copy-paste env only (no build/start commands)
# =============================================================================
# See `render.env.example` → replace placeholders → paste into Render → Environment → Bulk Edit
