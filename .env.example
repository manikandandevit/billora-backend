DJANGO_SECRET_KEY=replace-with-openssl-rand-hex-32-or-longer-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# IANA timezone for subscription calendar math (creation day → end date). Default UTC from settings.
# DJANGO_TIME_ZONE=Asia/Kolkata

# Production: DEBUG=False, USE_TLS=1, strong DJANGO_SECRET_KEY (48+ chars, not django-insecure / change-me)
# USE_TLS=1
# TRUST_PROXY_SSL=1
# SECURE_SSL_REDIRECT=1
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=1
# SECURE_HSTS_PRELOAD=0
# SESSION_COOKIE_SAMESITE=Lax
# CSRF_COOKIE_SAMESITE=Lax
# SECURE_REFERRER_POLICY=same-origin
# SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

# Supabase Postgres (pooler). Default DB on Supabase is often "postgres".
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your-password
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=6543

# Comma-separated origins for browser requests (scheme + host, no trailing slash).
# Defaults in settings.py include localhost + Billora Vercel (production + previews).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://billora-frontend.vercel.app
# Regex (optional pipe-separated). Omit to use built-in Billora Vercel pattern; use CORS_ALLOWED_ORIGIN_REGEXES=none to disable regex.
# CORS_ALLOWED_ORIGIN_REGEXES=
# Include your API/admin origins if users hit Django POST with cookies (defaults mirror CORS if unset).
# CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com,https://app.yourdomain.com

# JWT (SimpleJWT + blacklist + rotation)
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=14
JWT_LEEWAY_SECONDS=5
JWT_LOGIN_THROTTLE=20/minute
JWT_REFRESH_THROTTLE=60/minute
# Optional hardening
# JWT_ISSUER=https://api.yourcompany.com
# JWT_AUDIENCE=billora-api

# SMTP (Gmail: use an App Password, quoted if it contains spaces)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=your.sender@gmail.com
# EMAIL_HOST_PASSWORD="your-app-password"
# DEFAULT_FROM_EMAIL=Billora <your.sender@gmail.com>
# BILLORA_RECEIVER_EMAIL=ops@yourcompany.com

# Daily cron examples:
# python manage.py send_subscription_expiry_reminders
# python manage.py deactivate_expired_demo_clients
